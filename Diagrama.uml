@startuml

class Pessoa {
    - id : int
    - andarAtual : int
    - andarDestino : int
    - dentroElevador : boolean

    + chamarElevador()
    + entrarElevador()
    + sairElevador()
}

class Elevador {
    - andarAtual : int
    - capacidadeMaxima : int
    - pessoasDentro : List<Pessoa>
    - filaDestinos : List<int>
    - direcao : String

    + mover()
    + abrirPorta()
    + fecharPorta()
    + adicionarDestino(andar : int)
}

class Predio {
    - numeroAndares : int
    - elevador : Elevador
    - pessoas : List<Pessoa>

    + adicionarPessoa(p : Pessoa)
    + simularTurno()
}

class Simulador {
    - predio : Predio

    + iniciarSimulacao()
    + gerarPessoaAleatoria()
    + executar()
}

Predio "1" *-- "1" Elevador
Predio "1" *-- "many" Pessoa
Elevador "1" --> "many" Pessoa
Simulador --> Predio

@enduml